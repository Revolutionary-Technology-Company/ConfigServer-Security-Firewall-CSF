# Revolutionary Technology - SSH Hardening Profile
# Blocks authorized_keys modification and weird shell execution

#include <tunables/global>

/usr/sbin/sshd {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/authentication>

  # Capability requirements
  capability sys_chroot,
  capability sys_resource,
  capability dac_override,
  capability dac_read_search,
  capability setgid,
  capability setuid,
  capability sys_tty_config,
  capability net_bind_service,
  capability chown,
  capability fowner,
  capability kill,
  capability setpcap,
  capability sys_nice,
  capability audit_control,
  capability audit_write,

  # Network access
  network inet stream,
  network inet6 stream,

  # File permissions
  /etc/ssh/** r,
  /etc/hosts.allow r,
  /etc/hosts.deny r,
  /etc/passwd r,
  /etc/group r,
  /etc/shadow r,
  /var/log/** w,
  /run/sshd.pid w,

  # Deny writing to authorized_keys to prevent persistence
  deny /root/.ssh/authorized_keys w,
  deny /home/*/.ssh/authorized_keys w,

  # Execute shells (transition to unconfined for user sessions, or strict for restricted)
  /bin/bash ix,
  /bin/sh ix,
  
  # Allow managing user sessions
  /usr/sbin/sshd mr,
}