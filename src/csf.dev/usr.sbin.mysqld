# Revolutionary Technology - MySQL Hardening Profile
# Confines the MySQL server to data directories and prevents unauthorized access

#include <tunables/global>

/usr/sbin/mysqld {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/user-tmp>
  #include <abstractions/mysql>
  #include <abstractions/winbind>

  # Capability requirements
  capability dac_override,
  capability sys_resource,
  capability setgid,
  capability setuid,
  capability net_bind_service,
  capability chown,
  capability fowner,
  capability kill,
  capability setpcap,
  capability sys_nice,
  capability ipc_lock,

  # Network access
  network inet stream,
  network inet6 stream,
  network unix stream,

  # Process management
  /usr/sbin/mysqld mr,

  # Configuration files
  /etc/mysql/** r,
  /etc/my.cnf r,
  /etc/my.cnf.d/** r,
  /etc/hosts.allow r,
  /etc/hosts.deny r,

  # Data directories (adjust if your data dir is non-standard)
  /var/lib/mysql/ r,
  /var/lib/mysql/** rwk,
  
  # Log files
  /var/log/mysql/** rw,
  /var/log/mysqld.log rw,

  # PID and Socket files
  /var/run/mysqld/mysqld.pid rw,
  /var/run/mysqld/mysqld.sock rw,
  /run/mysqld/mysqld.pid rw,
  /run/mysqld/mysqld.sock rw,

  # Temporary files
  /tmp/** rw,

  # Prevent execution of shell commands from MySQL (common UDF exploit vector)
  deny /bin/sh x,
  deny /bin/bash x,
  deny /usr/bin/* x,
  
  # Prevent reading of sensitive system files
  deny /etc/shadow r,
  deny /etc/gshadow r,
  deny /root/** rwx,
}